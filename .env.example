# Database
DB_PASSWORD=your_mysql_password

# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key

# JWT (min 32 characters for HS256)
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars

# Optional overrides
DB_URL=jdbc:mysql://localhost:3306/chat
DB_USERNAME=root

# Qdrant vector DB (default works with docker compose)
QDRANT_URL=http://localhost:6333
